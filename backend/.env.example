# backend/.env — copy this file to backend/.env and fill in your keys
# Never commit backend/.env to git

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Intake model — Gemini 2.5 Flash (reuses GOOGLE_API_KEY, no new credentials needed)
# Falls back to gemini-2.5-flash (stable) if the preview model is unavailable.
GEMINI_INTAKE_MODEL=gemini-2.5-flash-preview-05-20
