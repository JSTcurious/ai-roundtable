# backend/.env — copy this file to backend/.env and fill in your keys
# Never commit backend/.env to git

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# OpenRouter — required for open-weight model evaluation (DeepSeek, Qwen, Llama)
# Get key at: https://openrouter.ai/keys
# Only needed for experiments/synthesizer_eval — not used in main app yet
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ════════════════════════════════════════════════════════════
# ai-roundtable Model Configuration
# All model IDs are env-overridable — no code changes needed.
# Role-based names only — no model names in variable names.
# ════════════════════════════════════════════════════════════

# ── Two tiers: Smart (default) and Deep (user opt-in) ────────
# Smart: Executor + Advisor pattern per lab
# Deep:  Top models with full thinking budget

# ── Gemini (Google) ──────────────────────────────────────────
# Note: Preview models — validated at startup by model_validator.py
RESEARCH_GEMINI_SMART_EXECUTOR=gemini-3-flash-preview
RESEARCH_GEMINI_SMART_ADVISOR=gemini-3.1-pro-preview
RESEARCH_GEMINI_DEEP=gemini-3.1-pro-preview
RESEARCH_GEMINI_FALLBACK=gemini-2.5-flash

# ── GPT (OpenAI) ──────────────────────────────────────────────
RESEARCH_GPT_SMART_EXECUTOR=gpt-5.4-mini
RESEARCH_GPT_SMART_ADVISOR=gpt-5.4
RESEARCH_GPT_DEEP=gpt-5.4
RESEARCH_GPT_FALLBACK=gpt-5.4-mini

# ── Grok (xAI) — participates in both Smart and Deep ─────────
RESEARCH_GROK_SMART_EXECUTOR=grok-4.1-fast-reasoning
RESEARCH_GROK_SMART_ADVISOR=grok-4.20-0309-reasoning
RESEARCH_GROK_DEEP=grok-4.20-0309-reasoning
RESEARCH_GROK_FALLBACK=grok-4.1-fast-non-reasoning

# ── Claude (Anthropic) ───────────────────────────────────────
# Opus 4.7:  $5/$25 per MTok, 1M context, Jan 2026 knowledge cutoff
# Sonnet 4.6: $3/$15 per MTok, 1M context, Aug 2025 knowledge cutoff
# Haiku 4.5:  $1/$5 per MTok,  200K context, Feb 2025 knowledge cutoff
RESEARCH_CLAUDE_SMART_EXECUTOR=claude-sonnet-4-6
RESEARCH_CLAUDE_SMART_ADVISOR=claude-opus-4-6
RESEARCH_CLAUDE_DEEP=claude-opus-4-6
RESEARCH_CLAUDE_FALLBACK=claude-haiku-4-5-20251001

# ── Fact-check ────────────────────────────────────────────────
# Perplexity is always primary — search-native, live citations.
# Fallback1 stays within Perplexity (cheaper Sonar tier).
# Fallback2 crosses to OpenAI only on full Perplexity outage.
# Depth controlled by prompt (Smart: 800 tokens, Deep: 2000 tokens).
FACTCHECK_PRIMARY=llama-3.1-sonar-large-128k-online
FACTCHECK_FALLBACK1=llama-3.1-sonar-small-128k-online
FACTCHECK_FALLBACK2=gpt-5.4
FACTCHECK_SMART_MAX_TOKENS=800
FACTCHECK_DEEP_MAX_TOKENS=2000

# ── Synthesis ─────────────────────────────────────────────────
# Analytical queries → Claude (leads on reasoning and attribution)
# Post-cutoff factual → GPT (handles Perplexity data without refusal)
# Fallback → Qwen (open-weight, 100% eval score, different provider)
SYNTHESIS_ANALYTICAL=claude-opus-4-6
SYNTHESIS_FACTUAL=gpt-5.4
SYNTHESIS_FALLBACK=qwen/qwen-2.5-72b-instruct

# ── Intake ────────────────────────────────────────────────────
# Always assigns smart tier — deep requires explicit user opt-in.
# Provider diversity across fallback chain for resilience.
# Primary:   GPT-4o Mini  (OpenAI — 16/16 eval score)
# Fallback1: Qwen 2.5 72B (OpenRouter — 16/16 eval score)
# Fallback2: Claude Haiku (Anthropic — last resort)
INTAKE_PRIMARY=claude-sonnet-4-6
INTAKE_FALLBACK1=qwen/qwen-2.5-72b-instruct
INTAKE_FALLBACK2=claude-haiku-4-5-20251001
